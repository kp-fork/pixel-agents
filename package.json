{
  "name": "pixel-agents",
  "displayName": "Pixel Agents",
  "description": "Pixel art office where your Claude Code agents come to life as animated characters",
  "version": "1.0.2",
  "publisher": "pablodelucca",
  "repository": {
    "type": "git",
    "url": "https://github.com/pablodelucca/pixel-agents"
  },
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pixel-agents.showPanel",
        "title": "Pixel Agents: Show Panel"
      },
      {
        "command": "pixel-agents.openInEditor",
        "title": "Pixel Agents: Open in Editor"
      },
      {
        "command": "pixel-agents.exportDefaultLayout",
        "title": "Pixel Agents: Export Layout as Default"
      },
      {
        "command": "pixel-agents.showRuntimeInfo",
        "title": "Pixel Agents: Show Runtime Info"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "pixel-agents-panel",
          "title": "Pixel Agents",
          "icon": "$(window)"
        }
      ]
    },
    "views": {
      "pixel-agents-panel": [
        {
          "type": "webview",
          "id": "pixel-agents.panelView",
          "name": "Pixel Agents"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "pixel-agents.openInEditor",
          "when": "view == pixel-agents.panelView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Pixel Agents",
      "properties": {
        "pixel-agents.claudeLaunchCommand": {
          "type": "string",
          "default": "claude",
          "description": "Command used when creating a new Claude terminal. Session ID placeholders are optional and not required for new sessions."
        },
        "pixel-agents.claudeResumeCommand": {
          "type": "string",
          "default": "claude --resume {sessionId}",
          "description": "Command used when opening a history session character. Supported placeholders: {sessionId}, ${sessionId}, $SESSION_ID, %SESSION_ID%. If no placeholder is present, --resume <id> is appended automatically."
        },
        "pixel-agents.historySessions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show recent session transcripts from this workspace as read-only history characters."
        },
        "pixel-agents.historySessions.lookbackDays": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 365,
          "description": "Include only sessions created in the last N days."
        },
        "pixel-agents.historySessions.maxVisible": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "maximum": 100,
          "description": "Maximum number of history session characters to show."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "dev:vscode": "npm run watch",
    "setup:desktop": "npm --prefix apps/desktop-electrobun install --no-fund --no-audit --cache /tmp/pixel-agents-npm-cache",
    "dev:desktop": "npm run setup:desktop && npm --prefix apps/desktop-electrobun run start",
    "dev:harness": "npm --prefix apps/view-harness run start",
    "build:webview": "cd webview-ui && npm run build",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run build:webview",
    "build": "npm run compile",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run build:webview",
    "package:vsix": "npx @vscode/vsce package --out pixel-agents-local.vsix",
    "install:vsix": "code --install-extension pixel-agents-local.vsix --force",
    "reinstall:vsix": "npm run package:vsix && npm run install:vsix",
    "build:pack": "node scripts/build-pack.js",
    "check-types": "npm-run-all check-types:*",
    "check-types:root": "tsc --noEmit --project tsconfig.json",
    "check-types:packages": "tsc --noEmit --project tsconfig.packages.json",
    "check-types:desktop-electrobun": "npm run setup:desktop && tsc --noEmit --project apps/desktop-electrobun/tsconfig.json",
    "check-types:view-harness": "tsc --noEmit --project apps/view-harness/tsconfig.json",
    "test:routing": "tsx scripts/test-jsonl-routing.ts",
    "test:team-tracking": "tsx scripts/test-team-tracking.ts",
    "test:overlay-state": "tsx scripts/test-tool-overlay-state.ts",
    "test:bubble-settings": "tsx scripts/test-bubble-settings.ts",
    "test:history-sessions": "tsx scripts/test-history-sessions.ts",
    "test:flow": "tsx scripts/verify-agent-flow.ts",
    "test:flow:batch": "tsx scripts/verify-agent-flow-batch.ts --limit 5",
    "test:runtime": "npm-run-all test:routing test:team-tracking test:overlay-state test:bubble-settings test:history-sessions test:flow",
    "verify:ops": "npm-run-all check-types test:runtime build",
    "verify:ops:vsix": "npm run verify:ops && npm run package:vsix",
    "lint": "eslint src",
    "import-tileset": "tsx scripts/import-tileset-cli.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/node": "22.x",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.107.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
