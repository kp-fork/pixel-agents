{
  "name": "@pixel-agents/desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "app:desktop:build:pty": "npm run build:pty",
    "app:desktop:start": "npm run start",
    "app:desktop:start:console": "npm run start:console",
    "app:desktop:start:electrobun": "npm run start:electrobun",
    "app:desktop:build": "npm run build",
    "app:desktop:package": "npm run package",
    "app:desktop:check-types": "npm run check-types",
    "build:pty": "node scripts/build-pty.mjs",
    "start": "electrobun dev",
