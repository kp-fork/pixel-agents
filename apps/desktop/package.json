    "start:electrobun": "electrobun dev",
    "build": "electrobun build",
    "package": "electrobun package",
    "check-types": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.18.12",
    "electrobun": "^1.14.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.3"
  }
