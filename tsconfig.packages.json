{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "packages/core/src/**/*.ts",
    "packages/view-model/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out"
  ]
}
